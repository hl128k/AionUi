{
  "$schema": "../../schemas/aion-extension-v1.json",
  "name": "ext-feishu",
  "displayName": "ext-飞书",
  "displayNameI18n": {
    "en": "ext-Feishu",
    "zh-CN": "ext-飞书",
    "zh": "ext-飞书"
  },
  "version": "0.1.0",
  "description": "Feishu Channels extension example (not integrated by default), demonstrates i18n, data collection hooks, and cross-runtime assets",
  "descriptionI18n": {
    "en": "Feishu Channels extension example for the extension framework",
    "zh-CN": "基于扩展框架的飞书 Channels 示例（默认未集成）",
    "zh": "基于扩展框架的飞书 Channels 示例（默认未集成）"
  },
  "author": "AionUI Contributors",
  "icon": "assets/ext-feishu.svg",
  "contributes": {
    "channelPlugins": [
      {
        "type": "ext-feishu",
        "name": "ext-飞书 Channel",
        "nameI18n": {
          "en": "ext-Feishu Channel",
          "zh-CN": "ext-飞书频道",
          "zh": "ext-飞书频道"
        },
        "description": "Feishu channel adapter sample with event dedupe and in-memory data collection",
        "entryPoint": "channels/ext-feishu-channel.js",
        "credentialFields": [
          {
            "key": "appId",
            "label": "App ID",
            "type": "text",
            "required": true
          },
          {
            "key": "appSecret",
            "label": "App Secret",
            "type": "password",
            "required": true
          }
        ],
        "configFields": [
          {
            "key": "enableMetrics",
            "label": "Enable Metrics",
            "type": "boolean",
            "default": true
          }
        ]
      }
    ],
    "webui": {
      "apiRoutes": [
        {
          "path": "/ext-feishu/collect",
          "entryPoint": "webui/collector.js",
          "description": "Collect extension telemetry events",
          "auth": true
        },
        {
          "path": "/ext-feishu/stats",
          "entryPoint": "webui/collector.js",
          "description": "Read extension telemetry stats",
          "auth": true
        }
      ],
      "staticAssets": [
        {
          "urlPrefix": "/ext-feishu/assets",
          "directory": "assets",
          "description": "Static assets for ext-feishu example"
        }
      ]
    }
  }
}
